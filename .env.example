# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
BETTER_AUTH_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
BETTER_AUTH_SECRET=super_secret_key_change_me

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=dev_user
POSTGRES_DB=dev_db
POSTGRES_PASSWORD=dev_password

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=admin_password

# ── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── ELK Stack (Elasticsearch / Logstash / Kibana) ────────────────────────────
# Credentials for Kibana login and internal ELK communication
ELASTIC_PASSWORD=changeme
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5101

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_PROXY_TARGET=http://backend:3000
VITE_STORAGE_PROXY_TARGET=http://minio:9000
VITE_IS_DEV=true

# ── Secrets ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=dev_password
PGADMIN_DEFAULT_PASSWORD=pgadmin 
BETTER_AUTH_SECRET=secrets
MINIO_SECRET_KEY=minioadmin
GOOGLE_CLIENT_ID=client_id
GOOGLE_CLIENT_SECRET=client_secret
